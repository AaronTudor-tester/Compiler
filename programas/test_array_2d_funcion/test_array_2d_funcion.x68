	CLR.L D1
	MOVE.W t28, D1
	MOVE.L D1, 0(A0, D0.L)
	; t29 = j
	MOVE.W j, t29
	; t30 = 1
	MOVE.W #1, t30
	; t31 = t29 + t30
	MOVE.W t29, D0
	ADD.W t30, D0
	MOVE.W D0, t31
	; j = t31
	MOVE.W t31, j
	; goto e2
	JMP e2
e3:
	; t32 = i
	MOVE.W i, t32
	; t33 = 1
	MOVE.W #1, t33
	; t34 = t32 + t33
	MOVE.W t32, D0
	ADD.W t33, D0
	MOVE.W D0, t34
	; i = t34
	MOVE.W t34, i
	; goto e0
	JMP e0
e1:
	; return null
	RTS
main:
	; t35 = 6
	MOVE.W #6, t35
	; t36 = 4
	MOVE.W #4, t36
	; t37 = t35 * t36
	MOVE.W t35, D0
