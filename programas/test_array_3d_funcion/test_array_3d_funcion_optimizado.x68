	ORG $1000
START:
	LEA STACKPTR, A7
	JMP main

; ===== RUTINAS AUXILIARES =====
PRINT_SIGNED:
	TST.W D1
	BPL PRINT_UNSIGNED
	MOVE.B #14, D0
	LEA MINUS_SIGN, A1
	TRAP #15
	NEG.W D1
PRINT_UNSIGNED:
	MOVE.B #3, D0
	TRAP #15
	RTS


ARRAY_INDEX_OUT_OF_BOUNDS:
	; Indice fuera de rango - mostrar mensaje y detener la simulacion
	LEA ERROR_INDEX_MSG, A1
	MOVE.B #14, D0
	TRAP #15
	SIMHALT

UNINITIALIZED_ACCESS:
	; Acceso a posicion no inicializada - mostrar mensaje y detener la simulacion
	LEA ERROR_UNINIT_MSG, A1
	MOVE.B #14, D0
	TRAP #15
	SIMHALT

ALLOC_SIZE_INVALID:
	; Tamaño de array inválido en tiempo de ejecución - mostrar mensaje y detener
	LEA ERROR_ALLOC_MSG, A1
	MOVE.B #14, D0
	TRAP #15
	SIMHALT
sumarCubo:
	; ; param cubo : INT_ARRAY_3
	; i = 0
	MOVE.W #0, i
e0:
	; t3 = i < 2
	MOVE.W #0, t3
	MOVE.W i, D0
	CMP.W #2, D0
	BLT t3_true
	JMP t3_false
t3_true:
	MOVE.W #1, t3
t3_false:
	; if !(t3) goto e1
	MOVE.W t3, D0
	CMP.W #0, D0
	BEQ e1
	; j = 0
	MOVE.W #0, j
e2:
	; t7 = j < 3
	MOVE.W #0, t7
	MOVE.W j, D0
	CMP.W #3, D0
	BLT t7_true
	JMP t7_false
t7_true:
	MOVE.W #1, t7
t7_false:
	; if !(t7) goto e3
	MOVE.W t7, D0
	CMP.W #0, D0
	BEQ e3
	; k = 0
	MOVE.W #0, k
e4:
	; t11 = k < 2
	MOVE.W #0, t11
	MOVE.W k, D0
	CMP.W #2, D0
	BLT t11_true
	JMP t11_false
t11_true:
	MOVE.W #1, t11
t11_false:
	; if !(t11) goto e5
	MOVE.W t11, D0
	CMP.W #0, D0
	BEQ e5
	; t15 = i * 3
	MOVE.W i, D0
	MULS #3, D0
	MOVE.W D0, t15
	; t16 = t15 + j
	MOVE.W t15, D0
	ADD.W j, D0
	MOVE.W D0, t16
	; t19 = t16 * 2
	MOVE.W t16, D0
	MULS #2, D0
	MOVE.W D0, t19
	; t20 = t19 + k
	MOVE.W t19, D0
	ADD.W k, D0
	MOVE.W D0, t20
	; t22 = t20 * 4
	MOVE.W t20, D0
	MULS #4, D0
	MOVE.W D0, t22
	; t26 = i * 3
	MOVE.W i, D0
	MULS #3, D0
	MOVE.W D0, t26
	; t27 = t26 + j
	MOVE.W t26, D0
	ADD.W j, D0
	MOVE.W D0, t27
	; t30 = t27 * 2
	MOVE.W t27, D0
	MULS #2, D0
	MOVE.W D0, t30
	; t31 = t30 + k
	MOVE.W t30, D0
	ADD.W k, D0
	MOVE.W D0, t31
	; t33 = t31 * 4
	MOVE.W t31, D0
	MULS #4, D0
	MOVE.W D0, t33
	; t34 = 12
	MOVE.W #12, t34
	; t40 = cubo[t33]
	MOVEA.L cubo, A0
	CLR.L D0
	MOVE.W t33, D0
	TST.L D0
	BMI ARRAY_INDEX_OUT_OF_BOUNDS
	MOVE.W t34, D2
	EXT.L D2
	MOVE.W #4, D3
	MULS D3, D2
	CMP.L D2, D0
	BGE ARRAY_INDEX_OUT_OF_BOUNDS
	MOVE.L 0(A0, D0.L), D1
	CMP.L #-1, D1
	BEQ UNINITIALIZED_ACCESS
	MOVE.W D1, t40
	; t42 = t40 + 1
	MOVE.W t40, D0
	ADD.W #1, D0
	MOVE.W D0, t42
	; cubo[t22] = t42
	MOVEA.L cubo, A0
	CLR.L D0
	MOVE.W t22, D0
	TST.L D0
	BMI ARRAY_INDEX_OUT_OF_BOUNDS
	CLR.L D1
	MOVE.W t42, D1
	MOVE.L D1, 0(A0, D0.L)
	; t45 = k + 1
	MOVE.W k, D0
	ADD.W #1, D0
	MOVE.W D0, t45
	; k = t45
	MOVE.W t45, k
	; goto e4
	JMP e4
e5:
	; t48 = j + 1
	MOVE.W j, D0
	ADD.W #1, D0
	MOVE.W D0, t48
	; j = t48
	MOVE.W t48, j
	; goto e2
	JMP e2
e3:
	; t51 = i + 1
	MOVE.W i, D0
	ADD.W #1, D0
	MOVE.W D0, t51
	; i = t51
	MOVE.W t51, i
	; goto e0
	JMP e0
e1:
	; return null
	RTS
main:
	; 
	MOVE.L HEAP_PTR, D0
	MOVE.L D0, miCubo
	MOVE.L #48, D1
	CMP.L #1, D1
	BLT ALLOC_SIZE_INVALID
	ADD.L #48, D0
	MOVE.L D0, HEAP_PTR
	TST.L D1
	BEQ INIT_miCubo_LOOP_END
	MOVE.L miCubo, A0
INIT_miCubo_LOOP:
	MOVE.L #-1, D4
	MOVE.L D4, (A0)+
	SUBQ.L #4, D1
	BGT INIT_miCubo_LOOP
INIT_miCubo_LOOP_END:
	; miCubo[0] = 1
	MOVEA.L miCubo, A0
	MOVE.L #0, D0
