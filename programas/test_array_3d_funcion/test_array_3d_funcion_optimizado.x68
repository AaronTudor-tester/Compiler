	BMI ARRAY_INDEX_OUT_OF_BOUNDS
	MOVE.L #12, D1
	MOVE.L D1, 0(A0, D0.L)
	; output "Cubo 3D original:"
	LEA str0, A1
	MOVE.B #14, D0
